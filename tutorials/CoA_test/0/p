FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      p;
}
// ************************************************************************* //

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 10.06;

boundaryField
{
    inlet
    {
        type            zeroGradient;
    }

    // 3-Element Windkessel (RCR) on each outlet
    // All values in KINEMATIC units:
    //   R_kin = R_dyn / rho [m^-1.s^-1]
    //   C_kin = C_dyn * rho [m.s^2]
    //   p_kin = p_dyn / rho [m^2/s^2]
    // With rho = 1060 kg/m^3
    //
    // Example physiological values (placeholder — replace with
    // patient-specific values computed via Murray's law):
    //   MAP = 93.3 mmHg = 12443 Pa -> p_kin = 11.74 m^2/s^2
    //   80 mmHg diastolic = 10666 Pa -> p_kin = 10.06 m^2/s^2

    outlet1     // Descending aorta (largest outlet)
    {
        type            modularWKPressure;
        phi             phi;
        U               U;
        couplingMode    implicit;
        order           3;

        // Kinematic Windkessel parameters
        R               268765.33;      // [m^-1.s^-1]
        C               3.72e-6;        // [m.s^2]
        Z               268936.63;      // [m^-1.s^-1]

        p0              10.06;          // ~80 mmHg [m^2/s^2]
        p_1             10.06;
        q_1             0;
        q_2             0;
        q_3             0;

        value           uniform 10.06;
    }

    outlet2     // Brachiocephalic artery
    {
        type            modularWKPressure;
        phi             phi;
        U               U;
        couplingMode    implicit;
        order           3;

        R               1108115.88;     // Higher R = smaller outlet
        C               9.024e-7;
        Z               268937.17;

        p0              10.06;
        p_1             10.06;
        q_1             0;
        q_2             0;
        q_3             0;

        value           uniform 10.06;
    }

    outlet3     // Left common carotid
    {
        type            modularWKPressure;
        phi             phi;
        U               U;
        couplingMode    implicit;
        order           3;

        R               1505282.46;
        C               6.643e-7;
        Z               430432.62;

        p0              10.06;
        p_1             10.06;
        q_1             0;
        q_2             0;
        q_3             0;

        value           uniform 10.06;
    }

    outlet4     // Left subclavian
    {
        type            modularWKPressure;
        phi             phi;
        U               U;
        couplingMode    implicit;
        order           3;

        R               1845211.52;
        C               5.419e-7;
        Z               584310.42;

        p0              10.06;
        p_1             10.06;
        q_1             0;
        q_2             0;
        q_3             0;

        value           uniform 10.06;
    }

    wall_aorta
    {
        type            zeroGradient;
    }
}
// ************************************************************************* //
