FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    object      U;
}
// ************************************************************************* //

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (0 0 0);

boundaryField
{
    inlet
    {
        type            timeVaryingMappedFixedValue;
        offset          (0 0 0);
        setAverage      false;
    }

    // Two-parameter backflow stabilisation (betaT, betaN)
    // betaT: suppresses tangential vortices during backflow
    // betaN: 0 preserves Windkessel pressure-flow coupling
    outlet1
    {
        type                  stabilizedWindkesselVelocity;
        phi                   phi;
        betaT                 0.2;
        betaN                 0.0;
        enableStabilization   true;
        value                 uniform (0 0 0);
    }
    outlet2
    {
        type                  stabilizedWindkesselVelocity;
        phi                   phi;
        betaT                 0.2;
        betaN                 0.0;
        enableStabilization   true;
        value                 uniform (0 0 0);
    }
    outlet3
    {
        type                  stabilizedWindkesselVelocity;
        phi                   phi;
        betaT                 0.2;
        betaN                 0.0;
        enableStabilization   true;
        value                 uniform (0 0 0);
    }
    outlet4
    {
        type                  stabilizedWindkesselVelocity;
        phi                   phi;
        betaT                 0.2;
        betaN                 0.0;
        enableStabilization   true;
        value                 uniform (0 0 0);
    }

    wall_aorta
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }
}
// ************************************************************************* //
