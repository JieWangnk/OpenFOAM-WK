FoamFile
{
    format      ascii;
    class       volScalarField;
    object      p;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    inlet
    {
        type            zeroGradient;
    }
    outlet
    {
        type            modularWKPressure;
        phi             phi;
        order           2;              // BDF2 time discretisation

        // Windkessel parameters in KINEMATIC units (consistent with OpenFOAM p field)
        // Conversion: R_kin = R_dyn/rho, C_kin = C_dyn*rho, p_kin = p_dyn/rho
        // Using rho = 1060 kg/m^3:
        //   R_dyn = 13330 Pa.s/m^3  -> R_kin = 13330/1060 = 12.575 m^-1.s^-1
        //   C_dyn = 1e-5 m^3/Pa     -> C_kin = 1e-5*1060  = 0.0106 m.s^2
        //   p_dyn = 10666 Pa         -> p_kin = 10666/1060  = 10.06 m^2/s^2
        R               12.575;         // Distal resistance [m^-1.s^-1]
        C               0.0106;         // Compliance [m.s^2]
        Z               0;              // Impedance (0 for 2-element WK)

        // Initial state (kinematic)
        p0              10.06;          // ~80 mmHg [m^2/s^2]
        p_1             10.06;
        q_1             0;
        q_2             0;
        q_3             0;

        value           uniform 10.06;
    }
    upperWall
    {
        type            zeroGradient;
    }

    lowerWall
    {
        type            zeroGradient;
    }

    frontAndBack
    {
        type            empty;
    }
}

